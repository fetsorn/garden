---
pagination:
  data: nav
  size: 1
  alias: world
permalink: "worlds/{{ world.slug }}.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Language" content="en, ru">
  <title>{{ world.label.en }} — {{ site.title }}</title>
  <link rel="stylesheet" href="../index.css">
</head>
<body class="world--{{ world.slug }}">
  {% include "partials/lang.njk" %}

  {% set langs = ['en', 'ru'] %}
  {% for lang in langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    {% set currentWorld = world.slug %}
    {% set currentRoom = null %}
    {% set navLang = lang %}
    {% include "partials/miller.njk" %}

    <section class="world-scene">
      <p class="world-scene-prose">{{ world.scene[lang] or world.description[lang] }}</p>
    </section>

    {% for offer in world.offers %}
    <section class="world-offer">
      <h2 class="offer-name">{{ offer.label[lang] }}</h2>
      <p class="offer-scene">{{ offer.scene[lang] }}</p>
      <div class="offer-action">
        <a href="{{ offer.actionUrl }}" class="offer-cta" target="_blank" rel="noopener">{{ offer.actionLabel[lang] }}</a>
        <span class="offer-price">{{ offer.price[lang] }}</span>
      </div>
    </section>
    {% endfor %}

    <section class="world-rooms">
      <p class="world-rooms-heading">
        {% if lang == 'en' %}Deeper in:{% else %}Дальше:{% endif %}
      </p>
      {% for room in world.rooms %}
      <a href="../rooms/{{ room.slug }}.html" class="world-room-link">
        <h3>{{ room.label[lang] }}</h3>
      </a>
      {% endfor %}
    </section>

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

</body>
</html>
