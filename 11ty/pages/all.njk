---
permalink: "all.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Language" content="en, ru">
  <title>Index — {{ site.title }}</title>
  <link rel="stylesheet" href="index.css">
</head>
<body class="all-index">
  {% include "partials/lang.njk" %}

  {% set langs = ['en', 'ru'] %}
  {% for lang in langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    <div class="all-header">
      <h1>{% if lang == 'en' %}Index{% elif lang == 'zh' %}索引{% else %}Указатель{% endif %}</h1>
      {% set switcherLangs = langs %}
      {% include "partials/lang-switcher.njk" %}
    </div>

    {% for place in places %}
    <section class="all-place">
      <h2><a href="rooms/{{ place.slug }}.html#{{ lang }}">{{ place.label[lang] }}</a></h2>
      <ul>
        {% for lm in place.landmarks %}
        <li>
          <span class="all-type">{{ lm.type }}</span>
          {% if lm.type == "Offer" and lm.offerSlug %}
          <a href="offers/{{ lm.offerSlug }}.html#{{ lang }}">{{ lm.label[lang] }}</a>
          {% elif lm.type == "Item" and lm.url %}
          <a href="{{ lm.url }}">{{ lm.label[lang] }}</a>
          {% elif lm.type == "Item" %}
          <a href="items/{{ lm.slug }}.html#{{ lang }}">{{ lm.label[lang] }}</a>
          {% elif lm.type == "Feed" %}
          <a href="feeds/{{ lm.slug }}.html#{{ lang }}">{{ lm.label[lang] }}</a>
          {% else %}
          {{ lm.label[lang] }}
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endfor %}

    <footer>
      <a href="index.html">{{ site.title }}</a>
    </footer>
  </div>
  {% endfor %}

</body>
</html>
