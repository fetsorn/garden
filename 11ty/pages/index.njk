---
permalink: "index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Language" content="en, ru">
  <title>{{ site.title }}</title>
  <link rel="stylesheet" href="index.css">
</head>
<body class="gate">
  {% include "partials/lang.njk" %}

  {% set langs = ['en', 'ru'] %}
  {% for lang in langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    <div class="gate-lang">
      {% set switcherLangs = langs %}
      {% include "partials/lang-switcher.njk" %}
    </div>

    <div class="gate-intro">
      <h1 class="gate-name">fetsorn</h1>
      <p class="gate-tagline">
        {% if lang == 'en' %}I work with language.{% else %}Я работаю со словом.{% endif %}
      </p>
    </div>

    <div class="gate-random">
      <button class="gate-random-btn" onclick="__goRandom()">
        {% if lang == 'en' %}wander{% else %}куда-нибудь{% endif %}
      </button>
    </div>

    <footer>
      <a href="all.html">
        {% if lang == 'en' %}index{% else %}карта сайта{% endif %}
      </a>
    </footer>
  </div>
  {% endfor %}

  <script>
    var __pages=[
      {% for p in nav %}"rooms/{{ p.slug }}.html",{% endfor %}
      {% for f in feedPages %}"feeds/{{ f.slug }}.html",{% endfor %}
      {% for p in prose %}"items/{{ p.slug }}.html",{% endfor %}
    ];
    function __goRandom(){
      var url=__pages[Math.floor(Math.random()*__pages.length)];
      location.href=url+'#'+(__lang||'en');
    }
  </script>

</body>
</html>
