---
permalink: "index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Language" content="en, ru">
  <title>{{ site.title }}</title>
  <link rel="stylesheet" href="index.css">
</head>
<body class="gate">
  {% set pageLangs = site.langs %}
  {% include "partials/lang.njk" %}

  {% set langs = site.langs %}
  {% for lang in langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    <div class="gate-lang">
      {% set switcherLangs = langs %}
      {% include "partials/lang-switcher.njk" %}
    </div>

    <div class="gate-intro">
      <h1 class="gate-name">fetsorn</h1>
      <p class="gate-tagline">
        {% if lang == 'en' %}Helping humans understand each other.
        {% elif lang == 'ru' %}Помогаю людям понять друг друга.
        {% elif lang == 'zh' %}帮助人类相互理解
        {% else %}🤝{% endif %}
      </p>
    </div>

    <div class="gate-random">
      <button class="gate-random-btn" onclick="__goRandom()">
        {% if lang == 'en' %}wander
        {% elif lang == 'ru' %}куда-нибудь
        {% elif lang == 'zh' %}漫步
        {% else %}🎲{% endif %}
      </button>
    </div>

    <footer>
      <a href="all.html">
        {% if lang == 'en' %}index
        {% elif lang == 'ru' %}карта сайта
        {% elif lang == 'zh' %}地图
        {% else %}🗺️{% endif %}
      </a>
    </footer>
  </div>
  {% endfor %}

  <script>
    var __pages=[
      {% for p in nav %}"spaces/{{ p.slug }}.html",{% endfor %}
      {% for f in feedPages %}"feeds/{{ f.slug }}.html",{% endfor %}
      {% for it in items.templated %}"items/{{ it.slug }}.html",{% endfor %}
      {% for it in items.passthrough %}"items/{{ it.slug }}.html",{% endfor %}
    ];
    function __goRandom(){
      var url=__pages[Math.floor(Math.random()*__pages.length)];
      location.href=url+'#'+(__lang||'en');
    }
  </script>

</body>
</html>
