<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = place.label.en %}
  {% set pageDescription = place.label.en + " — " + site.title %}
  {% set pageLangs = place.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="place-{{ place.slug }}">
  {% include "partials/lang.njk" %}

  {% for lang in place.langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    {% set currentPlace = place.slug %}
    {% set adjacentPlaces = place.adjacent %}
    {% set placeLandmarks = place.landmarks %}
    {% set navLang = lang %}
    {% set switcherLangs = place.langs %}
    {% include "partials/star.njk" %}

    {% if place.image %}
    <header>
      <img src="../img/{{ place.image }}"
           alt="{{ place.description[lang] }}">
    </header>
    {% endif %}

    <section class="place-description">
      <p>{{ place.description[lang] }}</p>
    </section>

    {% for lm in place.landmarks %}

    {% if lm.type == "Item" %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-item status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.url %}
      <a href="{{ lm.url }}">{{ lm.label[lang] }}</a>
      {% else %}
      <a href="../items/{{ lm.slug }}.html">{{ lm.label[lang] }}</a>
      {% endif %}
    </section>

    {% elif lm.entries %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-entries status-{{ lm.status }}">
      <h2><a href="../feeds/{{ lm.slug }}.html#{{ lang }}">{{ lm.label[lang] }}</a></h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      <ul class="entries">
        {% for entry in lm.entries %}
        {% if not entry.prose or entry.proseLangs[lang] %}
        <li>
          {% if entry.prose %}
          <a href="../items/{{ entry.slug }}.html">{{ entry.label[lang] }}</a>
          {% else %}
          <a href="{{ entry.url }}">{{ entry.label[lang] }}</a>
          {% endif %}
          {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </section>

    {% elif lm.category %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-feed status-{{ lm.status }}">
      <h2><a href="../feeds/{{ lm.slug }}.html#{{ lang }}">{{ lm.label[lang] }}</a></h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.items and lm.items[lang] | length %}
      <ul class="feed">
        {% for item in lm.items[lang] %}
        <li><a href="../items/{{ item.slug }}.html">{{ item.title }}</a> <time>{{ item.date }}</time></li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% endif %}

    {% endfor %}

    {% if place.offers | length %}
    <section class="place-commerce">
      {% for offer in place.offers %}
      <div class="place-offer">
        <h2 class="offer-name">{{ offer.label[lang] }}</h2>
        <p class="offer-scene">{{ offer.scene[lang] }}</p>
        <div class="offer-action">
          {% if offer.slug %}
          <a href="../offers/{{ offer.slug }}.html#{{ lang }}" class="offer-cta">{{ offer.actionLabel[lang] }}</a>
          {% else %}
          <a href="{{ offer.actionUrl }}" class="offer-cta" target="_blank" rel="noopener">{{ offer.actionLabel[lang] }}</a>
          {% endif %}
          <span class="offer-price">{{ offer.price[lang] }}</span>
        </div>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

  <script>
    (function(){
      var T={{ place.label | dump | safe }};
      function u(){document.title=T[window.__lang]||T['en']||'{{ site.title }}';}
      if(window.__lang)u();
    })();
  </script>

</body>
</html>
