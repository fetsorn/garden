{# Three-column star view (ADR-0006)
   Column 1: adjacent places (fog-of-war)
   Column 2: current place (anchor)
   Column 3: items here (landmarks)
#}
<nav class="star">
  {# Column 1: adjacent places #}
  <ul class="star-col star-adjacent">
    {% for adj in adjacentPlaces %}
    <li>
      <a href="{{ adj.slug }}.html#{{ navLang }}">{{ adj.label[navLang] }}</a>
    </li>
    {% endfor %}
  </ul>

  {# Column 2: current place (always one) #}
  <ul class="star-col star-current">
    <li class="star-active">
      {% for p in nav %}
      {% if p.slug == currentPlace %}{{ p.label[navLang] }}{% endif %}
      {% endfor %}
    </li>
  </ul>

  {# Column 3: items here #}
  {% if placeLandmarks %}
  <ul class="star-col star-items">
    {% for lm in placeLandmarks %}
    <li>
      <a href="#{{ navLang }}-{{ lm.slug }}" class="star-landmark">{{ lm.label[navLang] }}</a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  {# Language dropdown #}
  <span class="star-lang">
    {% include "partials/lang-switcher.njk" %}
  </span>
</nav>
