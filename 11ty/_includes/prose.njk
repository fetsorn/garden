<!DOCTYPE html>
<html lang="{{ doc.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ doc.label[doc.lang] }} — {{ site.title }}">
  <meta name="author" content="{{ site.author }}">
  <title>{{ doc.label[doc.lang] }}</title>
  <link rel="stylesheet" href="../index.css">
</head>
<body class="room-{{ doc.room.slug }}">

  <header>
    <img src="../img/{{ doc.room.slug }}.jpg"
         alt="{{ doc.room.label[doc.lang] }}">
  </header>

  <nav>
    {% for door in doc.room.doors %}
    {% if doc.lang == "ru" %}
    <a href="../{{ door.targetSlug }}.html#ru">{{ door.label.ru }}</a>
    {% else %}
    <a href="../{{ door.targetSlug }}.html">{{ door.label.en }}</a>
    {% endif %}
    {% endfor %}
    <span class="lang-toggle">
      {% if doc.lang == "ru" %}
      <a href="#en">EN</a> / <span class="active">RU</span>
      {% else %}
      <span class="active">EN</span> / <a href="#ru">RU</a>
      {% endif %}
    </span>
  </nav>

  <p class="item-context">{{ doc.contextLabel[doc.lang] }} · {{ doc.room.label[doc.lang] }}</p>
  {% if doc.lang == "ru" %}
  <p class="item-back"><a href="../{{ doc.room.slug }}.html#ru">&larr; назад</a></p>
  {% else %}
  <p class="item-back"><a href="../{{ doc.room.slug }}.html">&larr; back</a></p>
  {% endif %}

  <article class="item-body prose-body">
    {{ doc.content | safe }}
  </article>

  <footer>
    {% if doc.lang == "en" %}
    <a href="../en/prices.html">Support this work</a>
    {% else %}
    <a href="../ru/prices.html">Услуги и цены</a>
    {% endif %}
  </footer>

</body>
</html>
