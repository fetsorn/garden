<!DOCTYPE html>
<html lang="{{ doc.mainLang }}">
<head>
  {% set pageTitle = doc.label[doc.mainLang] %}
  {% set pageDescription = doc.label[doc.mainLang] + " — " + site.title %}
  {% set pageLangs = doc.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="{% if doc.mainLang != 'en' %}main-{{ doc.mainLang }} {% endif %}room-{{ doc.room.slug }}">

  {% for lang in doc.langs %}
  <div id="{{ lang }}"></div>
  {% endfor %}

  {% for lang in doc.langs %}
  <div class="lang-{{ lang }}" lang="{{ lang }}">
    <header>
      <img src="../img/{{ doc.room.image }}"
           alt="{{ doc.room.label[lang] }}">
    </header>

    {% set navDoors = doc.room.doors %}
    {% set navLang = lang %}
    {% set navLangs = doc.langs %}
    {% include "partials/navbar.njk" %}

    <p class="item-context">{{ doc.contextLabel[lang] }} · {{ doc.room.label[lang] }}</p>
    <p class="item-back">
      <a href="../rooms/{{ doc.room.slug }}.html#{{ lang }}">{% if lang == "ru" %}← назад{% elif lang == "zh" %}← 返回{% else %}← back{% endif %}</a>
    </p>

    <article class="item-body prose-body">
      {{ doc.content[lang] | safe }}
    </article>

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

  <script>
    (function(){
      var L={{ doc.langs | dump | safe }};
      function u(){var h=location.hash.slice(1);var l=L.indexOf(h)>=0?h:L[0];document.documentElement.lang=l;}
      u();addEventListener('hashchange',u);
    })();
  </script>

</body>
</html>
