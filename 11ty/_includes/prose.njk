<!DOCTYPE html>
<html lang="{{ doc.mainLang }}">
<head>
  {% set pageTitle = doc.label[doc.mainLang] %}
  {% set pageDescription = doc.label[doc.mainLang] + " — " + site.title %}
  {% set pageLangs = doc.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="{% if doc.mainLang != 'en' %}main-{{ doc.mainLang }} {% endif %}place-{{ doc.place.slug }}">
  {% include "partials/lang.njk" %}

  {% for lang in doc.langs %}
  <div id="{{ lang }}"></div>
  {% endfor %}

  {% for lang in doc.langs %}
  <div class="lang-{{ lang }}" lang="{{ lang }}">
    <header>
      <img src="../img/{{ doc.place.image }}"
           alt="{{ doc.place.label[lang] }}">
    </header>

    {% set adjacentPlaces = doc.place.adjacent %}
    {% set navLang = lang %}
    {% set navLangs = doc.langs %}
    {% set switcherLangs = doc.langs %}
    {% include "partials/navbar.njk" %}

    <p class="item-context">{{ doc.contextLabel[lang] }} · {{ doc.place.label[lang] }}</p>
    <p class="item-back">
      <a href="../rooms/{{ doc.place.slug }}.html#{{ lang }}">{% if lang == "ru" %}← назад{% elif lang == "zh" %}← 返回{% else %}← back{% endif %}</a>
    </p>

    <article class="item-body prose-body">
      {{ doc.content[lang] | safe }}
    </article>

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}


</body>
</html>
