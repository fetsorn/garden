<!DOCTYPE html>
<html lang="{{ doc.lang }}">
<head>
  {% set pageTitle = doc.label[doc.lang] %}
  {% set pageDescription = doc.label[doc.lang] + " — " + site.title %}
  {% set cssPath = "../index.css" %}
  {% include "partials/head.njk" %}
</head>
<body class="room-{{ doc.room.slug }}">

  <header>
    <img src="../img/{{ doc.room.slug }}.jpg"
         alt="{{ doc.room.label[doc.lang] }}">
  </header>

  {% set navDoors = doc.room.doors %}
  {% set navLang = doc.lang %}
  {% set navPrefix = "../" %}
  {% set navLangMode = "page" %}
  {% set navHasOtherLang = doc.hasOtherLang %}
  {% set navOtherLang = doc.otherLang %}
  {% set navSlug = doc.slug %}
  {% include "partials/navbar.njk" %}

  <p class="item-context">{{ doc.contextLabel[doc.lang] }} · {{ doc.room.label[doc.lang] }}</p>
  {% if doc.lang == "ru" %}
  <p class="item-back"><a href="../{{ doc.room.slug }}.html#ru">&larr; назад</a></p>
  {% else %}
  <p class="item-back"><a href="../{{ doc.room.slug }}.html">&larr; back</a></p>
  {% endif %}

  <article class="item-body prose-body">
    {{ doc.content | safe }}
  </article>

  {% include "partials/footer.njk" %}

</body>
</html>
