<!DOCTYPE html>
<html lang="{{ item.mainLang }}">
<head>
  {% set pageTitle = item.title %}
  {% set pageDescription = item.landmarkLabel[item.mainLang] + " — " + item.title %}
  {% set pageLangs = item.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="{% if item.mainLang != 'en' %}main-{{ item.mainLang }} {% endif %}place-{{ item.place.slug }}">
  {% include "partials/lang.njk" %}

  {% for lang in item.langs %}
  <div id="{{ lang }}"></div>
  {% endfor %}

  {% for lang in item.langs %}
  <div class="lang-{{ lang }}" lang="{{ lang }}">
    <header>
      <img src="../img/{{ item.place.image }}"
           alt="{{ item.place.label[lang] }}">
    </header>

    {% set adjacentPlaces = item.place.adjacent %}
    {% set navLang = lang %}
    {% set navLangs = item.langs %}
    {% set switcherLangs = item.langs %}
    {% include "partials/navbar.njk" %}

    <p class="item-context">{{ item.landmarkLabel[lang] }} · {{ item.place.label[lang] }}</p>
    <p class="item-back">
      <a href="../rooms/{{ item.place.slug }}.html#{{ lang }}">{% if lang == "ru" %}← назад{% elif lang == "zh" %}← 返回{% else %}← back{% endif %}</a>
    </p>

    {% if item.category == "legend" %}
    {% include "items/legend.njk" %}
    {% elif item.category == "poem-reading" %}
    {% include "items/poem-reading.njk" %}
    {% else %}
    {% include "items/default.njk" %}
    {% endif %}

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}


</body>
</html>
