<!DOCTYPE html>
<html lang="{{ item.lang }}">
<head>
  {% set pageTitle = item.title %}
  {% set pageDescription = item.landmarkLabel[item.lang] + " — " + item.title %}
  {% set cssPath = "../index.css" %}
  {% include "partials/head.njk" %}
</head>
<body class="room-{{ item.room.slug }}">

  <header>
    <img src="../img/{{ item.room.slug }}.jpg"
         alt="{{ item.room.label[item.lang] }}">
  </header>

  {% set navDoors = item.room.doors %}
  {% set navLang = item.lang %}
  {% set navPrefix = "../" %}
  {% set navLangMode = "page" %}
  {% set navHasOtherLang = item.hasOtherLang %}
  {% set navOtherLang = item.otherLang %}
  {% set navSlug = item.slug %}
  {% include "partials/navbar.njk" %}

  <p class="item-context">{{ item.landmarkLabel[item.lang] }} · {{ item.room.label[item.lang] }}</p>
  {% if item.lang == "ru" %}
  <p class="item-back"><a href="../{{ item.room.slug }}.html#ru">← назад</a></p>
  {% else %}
  <p class="item-back"><a href="../{{ item.room.slug }}.html">← back</a></p>
  {% endif %}

  {% if item.category == "legend" %}
  {% include "items/legend.njk" %}
  {% elif item.category == "poem-reading" %}
  {% include "items/poem-reading.njk" %}
  {% else %}
  {% include "items/default.njk" %}
  {% endif %}

  {% include "partials/footer.njk" %}

</body>
</html>
