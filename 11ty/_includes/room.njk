<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = room.label.en %}
  {% set pageDescription = room.label.en + " / " + room.label.ru + " — " + site.title %}
  {% set cssPath = "index.css" %}
  {% include "partials/head.njk" %}
</head>
{# The empty #ru anchor must be the first child of <body> —
   the CSS :target toggle uses ~ (general sibling combinator) to show/hide
   .lang-en / .lang-ru blocks. Moving this element will break the toggle. #}
<body class="room-{{ room.slug }}">

  <div id="ru"></div>

  {% for lang in ["en", "ru"] %}
  <div class="lang-{{ lang }}">
    <header>
      <img src="img/{{ room.slug }}.jpg"
           alt="{{ room.description[lang] }}">
    </header>

    {% set navDoors = room.doors %}
    {% set navLang = lang %}
    {% set navPrefix = "" %}
    {% set navLangMode = "hash" %}
    {% include "partials/navbar.njk" %}

    <section class="room-description">
      <p>{{ room.description[lang] }}</p>
    </section>

    {% for lm in room.landmarks %}

    {% if lm.type == "Item" %}
    <section id="{{ lm.slug }}{% if lang == 'ru' %}-ru{% endif %}" class="landmark landmark-item status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.url %}
      <a href="{{ lm.url }}">{{ lm.label[lang] }}</a>
      {% else %}
      <a href="{{ lang }}/{{ lm.slug }}.html">{{ lm.label[lang] }}</a>
      {% endif %}
    </section>

    {% elif lm.entries %}
    <section id="{{ lm.slug }}{% if lang == 'ru' %}-ru{% endif %}" class="landmark landmark-entries status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      <ul class="entries">
        {% for entry in lm.entries %}
        {% if not entry.prose or entry.proseLangs[lang] %}
        <li>
          {% if entry.prose %}
          <a href="{{ lang }}/{{ entry.slug }}.html">{{ entry.label[lang] }}</a>
          {% else %}
          <a href="{{ entry.url }}">{{ entry.label[lang] }}</a>
          {% endif %}
          {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </section>

    {% elif lm.category %}
    <section id="{{ lm.slug }}{% if lang == 'ru' %}-ru{% endif %}" class="landmark landmark-feed status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.items and lm.items[lang] | length %}
      <ul class="feed">
        {% for item in lm.items[lang] %}
        <li><a href="{{ lang }}/{{ item.slug }}.html">{{ item.title }}</a> <time>{{ item.date }}</time></li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% endif %}

    {% endfor %}

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

  <script>
    (function() {
      var titles = { en: {{ room.label.en | dump | safe }}, ru: {{ room.label.ru | dump | safe }} };
      function update() {
        var lang = location.hash === '#ru' ? 'ru' : 'en';
        document.title = titles[lang];
        document.documentElement.lang = lang;
      }
      update();
      window.addEventListener('hashchange', update);
    })();
  </script>

</body>
</html>
