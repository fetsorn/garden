<!DOCTYPE html>
<html lang="{{ room.mainLang }}">
<head>
  {% set pageTitle = room.label[room.mainLang] %}
  {% set pageDescription = room.label[room.mainLang] + " — " + site.title %}
  {% set pageLangs = room.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="{% if room.mainLang != 'en' %}main-{{ room.mainLang }} {% endif %}room-{{ room.slug }}">

  {% for lang in room.langs %}
  <div id="{{ lang }}"></div>
  {% endfor %}

  {% for lang in room.langs %}
  <div class="lang-{{ lang }}" lang="{{ lang }}">
    <header>
      <img src="../img/{{ room.image }}"
           alt="{{ room.description[lang] }}">
    </header>

    {% set navDoors = room.doors %}
    {% set navLang = lang %}
    {% set navLangs = room.langs %}
    {% include "partials/navbar.njk" %}

    <section class="room-description">
      <p>{{ room.description[lang] }}</p>
    </section>

    {% for lm in room.landmarks %}

    {% if lm.type == "Item" %}
    <section class="landmark landmark-item status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.url %}
      <a href="{{ lm.url }}">{{ lm.label[lang] }}</a>
      {% else %}
      <a href="../items/{{ lm.slug }}.html#{{ lang }}">{{ lm.label[lang] }}</a>
      {% endif %}
    </section>

    {% elif lm.entries %}
    <section class="landmark landmark-entries status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      <ul class="entries">
        {% for entry in lm.entries %}
        {% if not entry.prose or entry.proseLangs[lang] %}
        <li>
          {% if entry.prose %}
          <a href="../items/{{ entry.slug }}.html#{{ lang }}">{{ entry.label[lang] }}</a>
          {% else %}
          <a href="{{ entry.url }}">{{ entry.label[lang] }}</a>
          {% endif %}
          {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </section>

    {% elif lm.category %}
    <section class="landmark landmark-feed status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.items and lm.items[lang] | length %}
      <ul class="feed">
        {% for item in lm.items[lang] %}
        <li><a href="../items/{{ item.slug }}.html#{{ lang }}">{{ item.title }}</a> <time>{{ item.date }}</time></li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% endif %}

    {% endfor %}

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

  <script>
    (function(){
      var T={{ room.label | dump | safe }};
      var L={{ room.langs | dump | safe }};
      function u(){var h=location.hash.slice(1);var l=L.indexOf(h)>=0?h:L[0];document.title=T[l]||T[L[0]];document.documentElement.lang=l;}
      u();addEventListener('hashchange',u);
    })();
  </script>

</body>
</html>
