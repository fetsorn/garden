<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = room.label.en %}
  {% set pageDescription = room.label.en + " — " + site.title %}
  {% set pageLangs = room.langs %}
  {% include "partials/head.njk" %}
</head>
<body class="world--{{ room.world }} room-{{ room.slug }}">
  {% include "partials/lang.njk" %}

  {% for lang in room.langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    {% set currentWorld = room.world %}
    {% set currentRoom = room.slug %}
    {% set roomLandmarks = room.landmarks %}
    {% set navLang = lang %}
    {% include "partials/miller.njk" %}

    {% if room.image %}
    <header>
      <img src="../img/{{ room.image }}"
           alt="{{ room.description[lang] }}">
    </header>
    {% endif %}

    <section class="room-description">
      <p>{{ room.description[lang] }}</p>
    </section>

    {% for lm in room.landmarks %}

    {% if lm.type == "Item" %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-item status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.url %}
      <a href="{{ lm.url }}">{{ lm.label[lang] }}</a>
      {% else %}
      <a href="../items/{{ lm.slug }}.html">{{ lm.label[lang] }}</a>
      {% endif %}
    </section>

    {% elif lm.entries %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-entries status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      <ul class="entries">
        {% for entry in lm.entries %}
        {% if not entry.prose or entry.proseLangs[lang] %}
        <li>
          {% if entry.prose %}
          <a href="../items/{{ entry.slug }}.html">{{ entry.label[lang] }}</a>
          {% else %}
          <a href="{{ entry.url }}">{{ entry.label[lang] }}</a>
          {% endif %}
          {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </section>

    {% elif lm.category %}
    <section id="{{ lang }}-{{ lm.slug }}" class="landmark landmark-feed status-{{ lm.status }}">
      <h2>{{ lm.label[lang] }}</h2>
      <p class="landmark-description">{{ lm.description[lang] }}</p>
      {% if lm.items and lm.items[lang] | length %}
      <ul class="feed">
        {% for item in lm.items[lang] %}
        <li><a href="../items/{{ item.slug }}.html">{{ item.title }}</a> <time>{{ item.date }}</time></li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% endif %}

    {% endfor %}

    {% if room.offers.length or room.worldPatron %}
    <section class="room-commerce">
      {% for offer in room.offers %}
      <div class="world-offer">
        <h2 class="offer-name">{{ offer.label[lang] }}</h2>
        <p class="offer-scene">{{ offer.scene[lang] }}</p>
        <div class="offer-action">
          <a href="{{ offer.actionUrl }}" class="offer-cta" target="_blank" rel="noopener">{{ offer.actionLabel[lang] }}</a>
          <span class="offer-price">{{ offer.price[lang] }}</span>
        </div>
      </div>
      {% endfor %}

      {% if room.worldPatron %}
      <div class="world-offer offer-patron">
        <h2 class="offer-name">{{ room.worldPatron.label[lang] }}</h2>
        <p class="offer-scene">{{ room.worldPatron.scene[lang] }}</p>
        <div class="offer-action">
          <a href="{{ room.worldPatron.actionUrl }}" class="offer-cta" target="_blank" rel="noopener">{{ room.worldPatron.actionLabel[lang] }}</a>
          <span class="offer-price">{{ room.worldPatron.price[lang] }}</span>
        </div>
      </div>
      {% endif %}
    </section>
    {% endif %}

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

  <script>
    (function(){
      var T={{ room.label | dump | safe }};
      function u(){document.title=T[window.__lang]||T['en']||'{{ site.title }}';}
      if(window.__lang)u();
    })();
  </script>

</body>
</html>
