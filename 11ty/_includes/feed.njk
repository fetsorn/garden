<!DOCTYPE html>
<html lang="en">
<head>
  {% set pageTitle = feed.label.en %}
  {% set pageDescription = feed.label.en + " — " + site.title %}
  {% set pageLangs = feed.langs %}
  {% include "partials/head.njk" %}
</head>
<body>
  {% include "partials/lang.njk" %}

  {% for lang in feed.langs %}
  <div id="{{ lang }}" class="lang-{{ lang }}" lang="{{ lang }}">

    <p class="item-back">
      <a href="../index.html#{{ lang }}">{% if lang == "ru" %}← назад{% else %}← back{% endif %}</a>
    </p>

    <article class="feed-body">
      <h1>{{ feed.label[lang] }}</h1>

      {% if feed.entries | length %}
      <ul class="feed">
        {% for entry in feed.entries %}
        <li>
          {% if entry.hasProse %}
          <a href="../items/{{ entry.slug }}.html">{{ entry.name }}</a>
          {% elif entry.url %}
          <a href="{{ entry.url }}">{{ entry.name }}</a>
          {% else %}
          {{ entry.name }}
          {% endif %}
          {% if entry.date %}<time>{{ entry.date }}</time>{% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </article>

    {% include "partials/footer.njk" %}
  </div>
  {% endfor %}

</body>
</html>
