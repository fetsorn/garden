---
permalink: "/all.html"
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>index — {{ site.title | safe }}</title>
  <link rel="stylesheet" href="./index.css">
  <script src="lang.js"></script>
</head>
<body>
  <main>
    <h1>index</h1>
    <ul>
{%- for place in places %}
      <li>
        <a href="./{{ place.slug }}.html">
{%- if place.langs and place.langs.length > 1 %}
{%- for lang in place.langs %}
          <span lang="{{ lang }}">{{ place.title[lang] | safe }}</span>
{%- endfor %}
{%- elif place.title and place.langs %}
          {{ place.title[place.langs[0]] | safe }}
{%- else %}
          {{ place.slug }}
{%- endif %}
        </a>
      </li>
{%- endfor %}
    </ul>
  </main>
  <footer>
    <a href="./index.html">home</a>
  </footer>
</body>
</html>
