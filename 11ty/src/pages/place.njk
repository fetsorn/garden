---
pagination:
  data: places
  size: 1
  alias: place
permalink: "/{{ place.slug }}.html"
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ place.slug }}</title>
  <link rel="stylesheet" href="./index.css">
  <link rel="stylesheet" href="./hljs.css">
  <script src="lang.js"></script>
</head>
<body>
  <nav>
    <ul>
{%- for adj in place.adjacentPlaces %}
      <li>
        <a href="./{{ adj.slug }}.html">
{%- for lang in adj.langs %}
          <span lang="{{ lang }}">{{ adj.prose[lang] | truncate(40) }}</span>
{%- endfor %}
        </a>
      </li>
{%- endfor %}
    </ul>
    <div class="lang-toggle">
{%- for lang in place.langs %}
      <button data-lang="{{ lang }}" onclick="setLang('{{ lang }}')">{{ lang }}</button>
{%- endfor %}
    </div>
  </nav>
{%- for lang in place.langs %}
  <article lang="{{ lang }}"></article>
{%- endfor %}
  <footer>
    <a href="./crossroads.html">home</a>
{%- if place.access !== "private" %}
    <a href="./all.html">index</a>
{%- endif %}
  </footer>
</body>
</html>
